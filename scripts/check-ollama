#!/usr/bin/env python3
import re
import subprocess
import sys
from typing import List, Tuple

DEFAULT_COUNT = 10
TOPICS = ("ollama.done", "ollama.failed")
READ_PREFIX = ("./target/debug/plugboard", "read", "--topic")
ROW_START = re.compile(r"^(\S+)\t(\S+)\t(.*)$")

def parse_args() -> int:
    if len(sys.argv) == 1:
        return DEFAULT_COUNT
    if len(sys.argv) == 2 and sys.argv[1].isdigit() and int(sys.argv[1]) > 0:
        return int(sys.argv[1])
    print("usage: ./scripts/check-ollama [COUNT]", file=sys.stderr)
    raise SystemExit(2)


def read_topic(topic: str) -> List[Tuple[str, str, str]]:
    output = subprocess.run(
        [*READ_PREFIX, topic],
        check=True,
        text=True,
        capture_output=True,
    )

    entries: List[Tuple[str, str, str]] = []
    current = None
    for line in output.stdout.splitlines():
        match = ROW_START.match(line)
        if match:
            if current is not None:
                entries.append(current)
            current = (match.group(1), match.group(2), match.group(3))
            continue

        if current is None:
            continue

        current = (current[0], current[1], f"{current[2]}\n{line}")

    if current is not None:
        entries.append(current)

    return entries


def main() -> int:
    count = parse_args()
    rows: List[Tuple[str, str, str]] = []
    for topic in TOPICS:
        rows.extend(read_topic(topic))

    if not rows:
        print("No Ollama replies yet.")
        return 0

    rows.sort(key=lambda row: row[0])
    recent = rows[-count:]

    for index, (created_at, topic, body) in enumerate(recent, start=1):
        label = "done" if topic == "ollama.done" else "failed"
        print(f"[{label}] {created_at}")
        print(body)
        if index != len(recent):
            print()
            print("---")
            print()

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
