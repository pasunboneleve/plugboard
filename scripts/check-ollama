#!/usr/bin/env python3
import sqlite3
import sys
from pathlib import Path

DEFAULT_COUNT = 10
DEFAULT_DATABASE = Path(".plugboard/plugboard.db")


def parse_args() -> int:
    if len(sys.argv) == 1:
        return DEFAULT_COUNT
    if len(sys.argv) == 2 and sys.argv[1].isdigit() and int(sys.argv[1]) > 0:
        return int(sys.argv[1])
    print("usage: ./scripts/check-ollama [COUNT]", file=sys.stderr)
    raise SystemExit(2)


def main() -> int:
    count = parse_args()
    if not DEFAULT_DATABASE.exists():
        print("No Ollama replies yet.")
        return 0

    connection = sqlite3.connect(DEFAULT_DATABASE)
    rows = connection.execute(
        """
        SELECT created_at, topic, body
        FROM messages
        WHERE topic IN ('ollama.done', 'ollama.failed')
        ORDER BY created_at DESC, id DESC
        LIMIT ?
        """,
        (count,),
    ).fetchall()
    connection.close()

    if not rows:
        print("No Ollama replies yet.")
        return 0

    for index, (created_at, topic, body) in enumerate(reversed(rows), start=1):
        label = "done" if topic == "ollama.done" else "failed"
        print(f"[{label}] {created_at}")
        print(body)
        if index != len(rows):
            print()
            print("---")
            print()

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
