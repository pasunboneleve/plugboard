#!/usr/bin/env python3
import subprocess
import sys


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: ./scripts/check-ollama-conversation CONVERSATION_ID", file=sys.stderr)
        return 2

    conversation_id = sys.argv[1]
    completed = subprocess.run(
        [
            "./target/debug/plugboard",
            "check",
            "--conversation-id",
            conversation_id,
            "--success-topic",
            "ollama.done",
            "--failure-topic",
            "ollama.failed",
        ],
        text=True,
        capture_output=True,
    )

    if completed.stdout:
        print(completed.stdout, end="")
    if completed.stderr:
        print(completed.stderr, end="", file=sys.stderr)

    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
